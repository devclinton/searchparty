# SearchParty Environment Configuration
# Copy to .env and update values

# Database
SP_DATABASE_URL=postgresql://searchparty:searchparty@localhost:5432/searchparty

# Security - CHANGE THIS IN PRODUCTION
SP_SECRET_KEY=generate-a-secure-key-with-openssl-rand-hex-32

# Token expiry
SP_ACCESS_TOKEN_EXPIRE_MINUTES=30
SP_REFRESH_TOKEN_EXPIRE_DAYS=7
